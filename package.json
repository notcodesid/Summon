{
  "name": "summon",
  "packageManager": "npm@10.9.8",
  "scripts": {
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "android:apk": "cd android && ./gradlew assembleDappStoreRelease",
    "android:verify-apk": "node scripts/verify-android-apk.mjs",
    "build": "tsc --noEmit && npm run android:build",
    "ci": "tsc --noEmit && npm run lint:check && npm run format:check && npm run android:build && npm run seeker:verify-config",
    "dev": "expo start",
    "doctor": "npx -y expo-doctor@latest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ios": "expo run:ios",
    "lint": "expo lint --fix",
    "lint:check": "expo lint",
    "start": "expo start",
    "web": "expo start --web",
    "program:build": "npm run program:build-sbf && npm run program:build-idl && npm run program:sync-idl && npm run program:verify-idl",
    "program:build-sbf": "NO_DNA=1 cargo build-sbf --manifest-path programs/summon/Cargo.toml --sbf-out-dir target/deploy",
    "program:build-idl": "RUSTUP_TOOLCHAIN=1.89.0-aarch64-apple-darwin cargo run --manifest-path scripts/idl-builder/Cargo.toml --offline",
    "program:test": "NO_DNA=1 cargo test -p summon",
    "backend:check": "npm run program:test && npm run program:build",
    "program:sync-idl": "node scripts/sync-program-idl.mjs",
    "program:verify-idl": "node scripts/verify-program-idl.mjs",
    "seeker:verify-config": "node scripts/verify-seeker-config.mjs",
    "seeker:check-release": "node scripts/check-seeker-release.mjs"
  },
  "displayName": "Summon",
  "description": "Real-world animal collection and battles on Solana — initial mobile shell.",
  "usecase": "Mobile",
  "keywords": [
    "expo",
    "react-native",
    "solana",
    "mobile"
  ],
  "main": "./index.js",
  "version": "1.0.0",
  "dependencies": {
    "@anchor-lang/core": "^1.1.2",
    "@ethersproject/shims": "^5.8.0",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.15.5",
    "@privy-io/expo": "^0.70.1",
    "@privy-io/expo-native-extensions": "^0.0.12",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/dropdown-menu": "^1.2.0",
    "@solana/spl-memo": "^0.2.5",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.90.7",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "expo": "~55.0.23",
    "expo-apple-authentication": "~55.0.14",
    "expo-application": "~55.0.16",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.16",
    "expo-dev-client": "~55.0.18",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.16",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.15",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-web-browser": "~55.0.17",
    "fast-text-encoding": "^1.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-passkeys": "^0.4.1",
    "react-native-quick-crypto": "^0.7.17",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
