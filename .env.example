# Client-safe (bundled into the Expo app via EXPO_PUBLIC_*)
EXPO_PUBLIC_PRIVY_APP_ID=
# Privy Dashboard → Configuration → App settings → Clients
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Public support details required by the Solana dApp Store publisher policy.
EXPO_PUBLIC_SUPPORT_EMAIL=
EXPO_PUBLIC_PRIVACY_URL=https://github.com/notcodesid/Summon/blob/main/PRIVACY.md

# Server-only. NEVER prefix with EXPO_PUBLIC_ and never ship in the mobile binary.
PRIVY_APP_SECRET=

# Replace after generating the deploy keypair and running `anchor keys sync`.
EXPO_PUBLIC_SUMMON_PROGRAM_ID=9YnD3AaxVSAhigDfQemiKAAjbuieSBMA8cYUrpWLnZnZ

# Public MagicBlock Devnet Asia Ephemeral Rollup endpoints.
EXPO_PUBLIC_MAGICBLOCK_ER_RPC_URL=https://devnet-as.magicblock.app
EXPO_PUBLIC_MAGICBLOCK_ER_WS_URL=wss://devnet-as.magicblock.app
